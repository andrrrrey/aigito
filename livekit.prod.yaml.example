port: 7880
rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 60000
  use_external_ip: true
  node_ip: YOUR_SERVER_IP
  allow_tcp_fallback: true
  # Request keyframes faster on packet loss — reduces video freeze duration
  pli_throttle:
    low_quality: 500ms
    mid_quality: 1s
    high_quality: 1s
keys:
  YOUR_LIVEKIT_API_KEY: YOUR_LIVEKIT_API_SECRET
logging:
  level: info
turn:
  enabled: true
  domain: YOUR_DOMAIN
  cert_file: /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem
  key_file: /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem
  tls_port: 5349
  udp_port: 3478
