# === Database ===
POSTGRES_USER=aigita
POSTGRES_PASSWORD=your_secure_password_here

# === LiveKit (self-hosted, keys must match livekit.yaml) ===
LIVEKIT_API_KEY=aigita_dev_key
LIVEKIT_API_SECRET=aigita_dev_secret_change_me
LIVEKIT_URL=ws://livekit:7880
# Public URL for Lemon Slice avatar (must be reachable from Lemon Slice servers)
LIVEKIT_PUBLIC_URL=wss://your-domain.com/rtc

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-key

# === Deepgram (streaming STT) ===
DEEPGRAM_API_KEY=your_deepgram_key

# === ElevenLabs ===
ELEVENLABS_API_KEY=your_elevenlabs_key

# === Lemon Slice ===
LEMONSLICE_API_KEY=your_lemonslice_key

# === Tavily (web search fallback) ===
TAVILY_API_KEY=your_tavily_key

# === App ===
JWT_SECRET=your_jwt_secret_here
ENVIRONMENT=development
